{
  "scx":{
    "logging": {
      "default": {
        "level": "d",
        "type": "console",
        "stored-directory": null,
        "stack-trace": false
      },
      "loggers": []
    },
    "http": {
      "port": 8080
    },
    "sql": {
      "url": "jdbc:mysql://127.0.0.1:3306/scx_test",
      "username": "root",
      "password": "root",
      "parameters": [
        "allowMultiQueries=true",
        "rewriteBatchedStatements=true",
        "createDatabaseIfNotExist=true"
      ]
    }
  },
  "template": {
    "root": "AppRoot:c"
  },
  "static-servers": [
    {
      "location": "/c2/*",
      "root": "AppRoot:c2"
    },
    {
      "location": "/*",
      "root": "AppRoot:c1/index.html"
    }
  ]
}
